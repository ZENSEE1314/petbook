# Backend
DATABASE_URL=sqlite:///./petbook.db
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168
FIRST_ADMIN_EMAIL=admin@petbook.local

# Subscription
SUBSCRIPTION_PRICE_CENTS=1000
SUBSCRIPTION_PERIOD_DAYS=365

# Stripe (leave blank to use the dev stub)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# LLM (leave blank to use canned template)
ANTHROPIC_API_KEY=

# Deploy
# Comma-separated list of allowed CORS origins. When frontend is served from
# the same origin as the backend (Railway single-service), localhost is enough.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Persistent volume path for uploaded images. Leave blank in dev to use
# backend/app/static/uploads. On Railway, mount a volume and set to /data/uploads.
UPLOAD_DIR=
# Auto-run the seed script on first startup when the animals table is empty.
AUTO_SEED=true
